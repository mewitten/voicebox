{
  "name": "voicebox",
  "version": "0.1.0",
  "description": "A modern text-to-speech desktop application supporting multiple TTS engines",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "biome check --apply .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-builder",
    "release": "electron-builder --publish always"
  },
  "keywords": ["tts", "text-to-speech", "electron", "desktop"],
  "author": "voicebox contributors",
  "license": "MIT",
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^20.14.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.voicebox.app",
    "productName": "Voicebox",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": ".github/assets/icon-dark.webp",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
